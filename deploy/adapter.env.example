# 可选：自动化部署时用于覆盖页面配置。
# 日常推荐先启动服务，再在后台页面完成密钥、上游模型和策略配置。
ADAPTER_CONFIG=/opt/sub2api-adapter/configs/config.json
ADAPTER_LISTEN_ADDR=127.0.0.1:18080
ADAPTER_DB=/opt/sub2api-adapter/data/adapter.db
ADAPTER_HOST_BIND=127.0.0.1:18080
SUB2API_DOCKER_NETWORK=replace-with-sub2api-network-name
ADAPTER_IMAGE=614626370/sub2api-adapter
ADAPTER_VERSION=latest
ADAPTER_UPDATE_CHANNEL=latest
# 请替换为至少 32 位的随机字符串，Adapter 和独立更新器共同使用。
ADAPTER_UPDATE_TOKEN=replace-with-a-long-random-token
ADAPTER_ADMIN_USERNAME=admin
ADAPTER_ADMIN_PASSWORD=replace-with-a-long-random-password
ADAPTER_CONFIG_DIR=./configs
ADAPTER_MEMORY_LIMIT=512m
UPDATER_MEMORY_LIMIT=256m
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,::1
ADAPTER_AUTH_TOKEN=replace-with-long-random-token
ADAPTER_HASH_SALT=replace-with-random-hash-salt
UPSTREAM_PROVIDER=chat_json
UPSTREAM_BASE_URL=https://dashscope-us.aliyuncs.com/compatible-mode/v1
UPSTREAM_API_KEY=replace-with-upstream-api-key
UPSTREAM_MODEL=qwen3.6-flash-us
UPSTREAM_TIMEOUT_MS=2000
MODEL_DISABLED=false
ENABLE_FEW_SHOT=true
ENABLE_WRAP_USER_INPUT=true
ENABLE_SEARCH=false
ENABLE_THINKING=false
TEMPERATURE=0
TOP_P=1
SEGMENT_AUDIT_ENABLED=true
SEGMENT_AUDIT_THRESHOLD_CHARS=4000
SEGMENT_AUDIT_TARGET_CHARS=1800
SEGMENT_AUDIT_OVERLAP_CHARS=200
SEGMENT_AUDIT_MAX_SEGMENTS=8
SEGMENT_AUDIT_CONCURRENCY=3
SEGMENT_AUDIT_REVIEW_SCORE=0.5
SEGMENT_AUDIT_REVIEW_MAX_CHARS=6000
