[Unit]
Description=sub2api moderation adapter
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=sub2api
Group=sub2api
WorkingDirectory=/opt/sub2api-adapter
# 可选环境文件；常规配置可在后台页面保存到 SQLite。
EnvironmentFile=-/opt/sub2api-adapter/adapter.env
ExecStart=/opt/sub2api-adapter/moderation-adapter
Restart=always
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/opt/sub2api-adapter/data

[Install]
WantedBy=multi-user.target
