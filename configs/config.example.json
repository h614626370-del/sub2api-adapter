    "enable_few_shot": false,
    "wrap_user_input": true,
    "temperature": 0,
    "top_p": 1,
    "max_tokens": 300,
    "enable_search": false,
    "enable_thinking": false,
    "thinking_budget": 1,
    "enable_high_resolution_images": false,
    "timeout_ms": 3500
  },
