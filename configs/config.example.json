{
  "listen_addr": "127.0.0.1:18080",
  "database_path": "data/adapter.db",
  "auth_tokens": ["replace-with-a-long-random-token"],
  "force_allow": false,
  "max_body_bytes": 16777216,
  "direct_model_audit": false,
